/* pages/pair/pair.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #fff3e9;
}

/* 标题区 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  color: #d82626;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.tip {
  display: block;
  color: #666;
  font-size: 26rpx;
}

/* 模式切换按钮 */
.mode-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.mode-btn {
  padding: 10rpx 30rpx;
  background: #fff;
  border: 2rpx solid #ddd;
  border-radius: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.mode-btn.active {
  background: #e62727;
  color: #fff;
  border-color: #e62727;
}

/* 游戏容器 */
.game-container {
  max-width: 100%;
  margin: 0 auto;
  background: #ffffff;
  border-radius: 36rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.1);
}

/* 配对行 */
.pair-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx 0;
  gap: 24rpx;
  width: 100%;
}

.char-item {
  width: 30%;
}

.sign-item {
  width: 15%;
  text-align: center;
}

.img-item {
  width: 45%;
}

/* 汉字卡片 */
.char-card {
  background: #e62727;
  color: white;
  font-size: 80rpx;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 24rpx;
  border: 6rpx solid transparent;
}

.char-card.selected {
  border-color: #ffdd00;
  border-width: 10rpx;
  box-shadow: 0 0 20rpx #ffdd00, 0 0 40rpx #ffdd00;
  transform: scale(1.05);
}

/* 结果标记 */
.q-mark {
  font-size: 80rpx;
  font-weight: bold;
}

.q-default {
  color: #d82626;
}

.q-right {
  color: #179b43;
}

.q-wrong {
  color: #d62424;
}

/* 图片卡片 */
.img-card {
  border: 4rpx solid #e62727;
  border-radius: 24rpx;
  padding: 16rpx;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff8f8;
}

.img-card.highlight {
  border-color: #ffdd00;
  border-width: 8rpx;
  box-shadow: 0 0 20rpx #ffdd00, 0 0 40rpx #ffdd00;
  transform: scale(1.05);
}

.emoji-pic {
  font-size: 100rpx;
  line-height: 1;
}

/* 控制按钮 */
.control-area {
  margin-top: 50rpx;
  display: flex;
  justify-content: center;
}

.refresh-btn {
  padding: 20rpx 44rpx;
  font-size: 34rpx;
  border: none;
  border-radius: 20rpx;
  background: #e62727;
  color: white;
}

.refresh-btn::after {
  border: none;
}

/* 结果面板 */
.result-panel {
  text-align: center;
  margin-top: 30rpx;
  font-size: 36rpx;
  font-weight: bold;
  min-height: 50rpx;
}

.result-panel.right {
  color: #179b43;
}

.result-panel.wrong {
  color: #d62424;
}

/* 识字建议 */
.footer-copyright {
  text-align: center;
  margin-top: 40rpx;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #888;
}
