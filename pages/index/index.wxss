/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f0f8ff;
}

/* 游戏选择器 */
.game-selector {
  margin-bottom: 30rpx;
}

.game-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #eee;
}

.game-card:last-child {
  margin-bottom: 0;
}

.game-card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.game-card-desc {
  font-size: 24rpx;
  color: #888;
}

/* 标题 */
.title {
  text-align: center;
  color: #ff6b8b;
  font-size: 48rpx;
  margin-bottom: 30rpx;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 4rpx #fff;
}

/* 分类选择栏 */
.category-box {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 30rpx;
  justify-content: center;
}

.category-item {
  padding: 12rpx 20rpx;
  background: #409eff;
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: none;
}

.category-item.active {
  background: #ff6b8b;
}

/* 功能按钮区 */
.btn-box {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
  flex-wrap: wrap;
}

.func-btn {
  padding: 16rpx 32rpx;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.func-btn::after {
  border: none;
}

.prev-btn {
  background: #9c88ff;
}

.voice-btn {
  background: #e6a23c;
}

.next-btn {
  background: #36cfc9;
}

.random-btn {
  background: #67c23a;
}

/* 识字卡片 */
.card-container {
  width: 90%;
  max-width: 700rpx;
  height: 550rpx;
  background: #fff;
  border-radius: 40rpx;
  margin: 0 auto;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.char-pinyin {
  font-size: 56rpx;
  color: #409eff;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.char-text {
  font-size: 200rpx;
  color: #222;
  font-weight: bold;
  line-height: 1.2;
}

.char-desc {
  font-size: 32rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 进度文字 */
.progress-text {
  text-align: center;
  margin-top: 24rpx;
  color: #666;
  font-size: 28rpx;
}

/* 识字建议 */
.tip-box {
  margin-top: 50rpx;
  background: #fffef0;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid #ffeaa7;
}

.tip-title {
  color: #e6a23c;
  font-weight: bold;
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.tip-text {
  color: #666;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 底部署名 */
.copyright {
  text-align: center;
  margin-top: 50rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #888;
}
